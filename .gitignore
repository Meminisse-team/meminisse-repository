# 환경변수 (절대 커밋 금지 — DB 비밀번호, API 키 포함)
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
*.egg-info/
dist/
build/

# 가상환경
.venv/
venv/
env/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Alembic 자동생성 임시파일
alembic/versions/*.pyc

# DeepEval(backend/evals/, P3 정량 평가체계)이 로컬 실행 시 만드는 텔레메트리/캐시
# 파일 — 평가 결과 자체(backend/evals/results/)와는 별개로, 이건 순수 도구 부산물이다.
backend/.deepeval/

# 호스트에서 직접 `celery beat`를 띄우면 실행 디렉토리에 생기는 스케줄 상태 파일
# (Docker의 beat 서비스는 컨테이너 안에서 생성하므로 호스트에는 안 남음).
backend/celerybeat-schedule*

# 파일 로깅(app/core/logging_config.py) 산출물 — 관리자 대시보드 로그 열람용이며
# 커밋 대상이 아니다.
backend/logs/

# frontend/.gitignore가 node_modules, .next 등 Next.js 산출물을 별도로 관리한다.
