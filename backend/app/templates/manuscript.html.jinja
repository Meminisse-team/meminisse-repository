<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="utf-8">
<title>{{ title or "제목 없음" }}</title>
<style>
  @font-face {
    font-family: "Manuscript Serif";
    src: url("{{ font_url }}");
    font-weight: normal;
    font-style: normal;
  }

  /* 국판(A5) + 도련(bleed) 3mm + 제본 안쪽 여백을 바깥보다 넓게(inside > outside). */
  @page {
    size: 148mm 210mm;
    bleed: 3mm;
    marks: crop;
    margin: 20mm 15mm 20mm 20mm;
    @bottom-center {
      content: counter(page);
      font-family: "Manuscript Serif", serif;
      font-size: 9pt;
      color: #555;
    }
  }

  @page :first {
    @bottom-center { content: ""; }
  }

  * { box-sizing: border-box; }

  body {
    font-family: "Manuscript Serif", serif;
    font-size: 11pt;
    line-height: 1.9;
    color: #1a1a1a;
    /* 한글 금칙(줄바꿈이 단어 중간에서 일어나지 않도록) */
    word-break: keep-all;
    overflow-wrap: break-word;
    orphans: 3;
    widows: 3;
  }

  .cover {
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    break-after: page;
  }
  .cover h1 {
    font-size: 26pt;
    margin-bottom: 12mm;
  }
  .cover .subtitle {
    font-size: 11pt;
    color: #555;
    max-width: 100mm;
    line-height: 1.8;
  }

  .toc {
    break-after: page;
  }
  .toc h2 {
    font-size: 16pt;
    margin-bottom: 10mm;
  }
  .toc ol {
    list-style: none;
    padding: 0;
  }
  .toc li {
    display: flex;
    justify-content: space-between;
    gap: 4mm;
    font-size: 11pt;
    margin-bottom: 4mm;
    border-bottom: 1px dotted #999;
  }
  .toc-part h3 {
    font-size: 12pt;
    margin: 6mm 0 3mm 0;
  }

  .part-divider {
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    break-before: page;
    break-after: page;
  }
  .part-divider .part-label {
    font-size: 10pt;
    letter-spacing: 0.2em;
    color: #777;
    margin-bottom: 4mm;
  }
  .part-divider h2 {
    font-size: 20pt;
  }

  .chapter {
    break-before: page;
  }
  .chapter h2 {
    font-size: 15pt;
    margin-bottom: 8mm;
    text-align: center;
  }
  .chapter .photo {
    display: block;
    max-width: 100%;
    max-height: 70mm;
    margin: 0 auto 6mm auto;
    object-fit: cover;
  }
  .chapter figure {
    margin: 0 0 6mm 0;
    break-inside: avoid;
  }
  .chapter figcaption {
    margin-top: 2mm;
    text-align: center;
    font-size: 9pt;
    color: #555;
  }
  .chapter p {
    margin: 0 0 4mm 0;
    text-indent: 1em;
    break-inside: avoid;
  }

  /* 전면 사진 페이지형 슬롯(기획안 5절) — 사진 한 장이 한 페이지를 차지한다. */
  .photo-page {
    break-before: page;
    break-after: page;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }
  .photo-page img {
    max-width: 100%;
    max-height: 150mm;
    object-fit: contain;
  }
  .photo-page .photo-caption {
    margin-top: 4mm;
    font-size: 9pt;
    color: #555;
    text-align: center;
  }
</style>
</head>
<body>

<section class="cover">
  <h1>{{ title or "나의 이야기" }}</h1>
  {% if book_synopsis %}
  <p class="subtitle">{{ book_synopsis }}</p>
  {% endif %}
</section>

<section class="toc">
  <h2>목차</h2>
  {% if parts %}
    {% for part in parts %}
    <div class="toc-part">
      <h3>{{ part.part_index }}부. {{ part.part_title }}</h3>
      <ol>
        {% for chapter in chapters if chapter.part_index == part.part_index %}
        <li><span>{{ chapter.chapter_index }}장. {{ chapter.title or "" }}</span></li>
        {% endfor %}
      </ol>
    </div>
    {% endfor %}
  {% else %}
  <ol>
    {% for chapter in chapters %}
    <li><span>{{ chapter.chapter_index }}장. {{ chapter.title or "" }}</span></li>
    {% endfor %}
  </ol>
  {% endif %}
</section>

{% for chapter in chapters %}
{% if chapter.is_part_opening %}
<section class="part-divider">
  <p class="part-label">PART {{ chapter.part_index }}</p>
  <h2>{{ chapter.part_title }}</h2>
</section>
{% endif %}
{% for photo in chapter.full_page_photos %}
<section class="photo-page">
  <img src="{{ photo.url }}" alt="">
  {% if photo.caption %}<p class="photo-caption">{{ photo.caption }}</p>{% endif %}
</section>
{% endfor %}
<section class="chapter">
  <h2>{{ chapter.chapter_index }}장. {{ chapter.title or "" }}</h2>
  {% for photo in chapter.top_photos %}
  <figure>
    <img class="photo" src="{{ photo.url }}" alt="">
    {% if photo.caption %}<figcaption>{{ photo.caption }}</figcaption>{% endif %}
  </figure>
  {% endfor %}
  {% for paragraph in chapter.paragraphs %}
  <p>{{ paragraph }}</p>
  {% endfor %}
</section>
{% endfor %}

</body>
</html>
