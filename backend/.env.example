# ── 게이트웨이 백엔드 (app/gateways/factory.py) ────────────────────────────────
# mock: DB/S3 없이 인메모리로 전체 API를 실행(로컬 데모·테스트). postgres: 실제 Supabase 연결.
GATEWAY_BACKEND=postgres

# ── Supabase PostgreSQL ────────────────────────────────────────────────────────
# Supabase Dashboard → Settings → Database → Connection String → URI
# "postgresql://" 를 "postgresql+asyncpg://" 로 교체하여 사용
#
# [반드시 Direct connection 사용] 포트 5432 (db.[ref].supabase.co)
#   → asyncpg + SQLAlchemy + Alembic DDL 완전 호환
#
# [Pooler 포트 6543 사용 금지]
#   → asyncpg prepared statement 캐시와 충돌 → 런타임 오류 발생
#
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.euzmnstknihfumpgdahx.supabase.co:5432/postgres

# ── AWS S3 (미디어 원본 저장) ──────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=meminisse-media
AWS_REGION=ap-northeast-2

# ── Upstage (Solar LLM + Embeddings) ───────────────────────────────────────────
# 발급: https://console.upstage.ai → API Keys
# 하나의 키로 2종 API 모두 인증
#   Solar LLM       → AsyncOpenAI(base_url="https://api.upstage.ai/v1", api_key=UPSTAGE_API_KEY), model="solar-pro3"
#   Embeddings      → 같은 클라이언트, model="embedding-query" | "embedding-passage"
# NOTE: Embeddings 응답 벡터 차원이 Upstage 문서 내에서 4096/1024로 서로 모순되어 있음.
#       실제 키 발급 후 1회 호출로 차원을 확인하고, app/models/base.py EMBEDDING_DIM 및
#       alembic/versions/002_event_first_class_object.py의 vector(N)과 일치하는지 검증할 것.
UPSTAGE_API_KEY=up_xxxxxxxxxxxxxxxxxxxx

# ── Azure Computer Vision (사진 캡셔닝 + 사진 속 텍스트 인식) ──────────────────────
# 발급: https://portal.azure.com → "Computer Vision" 리소스 생성
#   AZURE_CV_ENDPOINT → 리소스 개요의 "엔드포인트" (예: https://<resource-name>.cognitiveservices.azure.com)
#   AZURE_CV_API_KEY  → 리소스의 "키 및 엔드포인트" → KEY 1 또는 KEY 2
# 사진 한 장당 API 호출 1번으로 캡션(예: "집 앞에서 5명이 함께 찍은 사진")과 사진 속
# 인쇄/손글씨 텍스트(예: "1990년 집 앞에서 가족들과.")를 함께 받아온다(Image Analysis
# 4.0, features=caption,read — app/clients/azure_vision.py). 둘 다 비워두면 사진
# 분석을 건너뛰고 일반적인 오프닝 질문으로 대체되므로(앱이 죽지 않음), 나중에 이
# 두 값만 채우면 코드 수정 없이 바로 동작한다.
AZURE_CV_ENDPOINT=
AZURE_CV_API_KEY=

# ── Celery + Redis (세션 후처리 / Phase 3·4 파이프라인 / PDF 조판 비동기 워커) ──
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── CORS (Next.js 개발 서버) ───────────────────────────────────────────────────
CORS_ALLOW_ORIGINS=["http://localhost:3000"]

# ── 인증 (Supabase Auth) ──────────────────────────────────────────────────────
# 회원가입/로그인(POST /api/v1/users, POST /api/v1/auth/login)을 이 Supabase
# 프로젝트에 이미 있는 인증 서비스(auth 스키마, GoTrue)에 위임한다. 전부 Supabase
# Dashboard → Settings → API에서 확인 가능:
SUPABASE_URL=https://euzmnstknihfumpgdahx.supabase.co
# "anon public" 키 — 로그인/토큰 갱신에 사용. 공개 가능한 키이지만 이 프로젝트는
# 백엔드가 대신 호출하므로 .env에만 둔다.
SUPABASE_ANON_KEY=
# "service_role" 키 — 회원가입 시 관리자 권한으로 이메일 인증 절차 없이 즉시 계정을
# 만드는 데 사용. RLS를 완전히 우회하는 매우 민감한 키다. 절대 프론트엔드나 커밋에
# 노출하지 말 것.
SUPABASE_SERVICE_ROLE_KEY=
# Settings → API → JWT Settings → "JWT Secret" — 세션 토큰(HS256) 서명 검증용.
SUPABASE_JWT_SECRET=
