# ── Supabase PostgreSQL ────────────────────────────────────────────────────────
# Supabase Dashboard → Settings → Database → Connection String → URI
# "postgresql://" 를 "postgresql+asyncpg://" 로 교체하여 사용
#
# [반드시 Direct connection 사용] 포트 5432 (db.[ref].supabase.co)
#   → asyncpg + SQLAlchemy + Alembic DDL 완전 호환
#
# [Pooler 포트 6543 사용 금지]
#   → asyncpg prepared statement 캐시와 충돌 → 런타임 오류 발생
#
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.euzmnstknihfumpgdahx.supabase.co:5432/postgres

# ── AWS S3 (미디어 원본 저장) ──────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=meminisse-media
AWS_REGION=ap-northeast-2

# ── Upstage (Solar LLM + Document Parse) ──────────────────────────────────────
# 발급: https://console.upstage.ai → API Keys
# 하나의 키로 두 서비스 모두 인증
#   Solar LLM      → AsyncOpenAI(base_url="https://api.upstage.ai/v1/solar", api_key=UPSTAGE_API_KEY)
#   Document Parse → POST https://api.upstage.ai/v1/document-ai/document-parse
UPSTAGE_API_KEY=up_xxxxxxxxxxxxxxxxxxxx

# ── OpenAI (임베딩 전용) ───────────────────────────────────────────────────────
# text-embedding-3-large (1536차원) — pgvector 하이브리드 검색 벡터 생성에만 사용
# 발급: https://platform.openai.com → API Keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
